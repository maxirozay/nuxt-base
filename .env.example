# server
NUXT_SESSION_PASSWORD={randomString(32)}
NUXT_SESSION_MAX_AGE=3600 # 1 hour
NUXT_REFRESH_TOKEN_MAX_AGE=2592000 # 1 month
NUXT_DB=postgres://{dbUser}:{dbPassword}@localhost:5432/{dbName}
NUXT_AUTO_SIGNUP=false
NUXT_FILES_PUBLIC_FOLDER=files/public # don't use public else it will overwrite nuxt folder
NUXT_FILES_PRIVATE_FOLDER=files/private
NUXT_LOGS_RETENTION_DAYS=90 # 90 days
NUXT_BACKUP_RETENTION_DAYS=30 # 30 days
NUXT_BACKUP_DUMP_ARGS="--data-only -F c"

# public
NUXT_PUBLIC_NAME="Nuxt Base"
NUXT_PUBLIC_URL=https://web.site
NUXT_PUBLIC_LOGO=https://placehold.co/200x100?text=logo
NUXT_PUBLIC_ANONYMOUS_SIGNUP=false
NUXT_PUBLIC_REFRESH_TOKEN_ROTATE_AFTER=86400 # get a new token after 1 day
NUXT_PUBLIC_FILES_URL=/files

# Oauth
NUXT_OAUTH_MICROSOFT_CLIENT_ID={clientId}
NUXT_OAUTH_MICROSOFT_CLIENT_SECRET={secret}
NUXT_OAUTH_MICROSOFT_TENANT={tenant}
NUXT_PUBLIC_OAUTH_MICROSOFT=true # display the sign in button

# S3 (optional - Leave empty for local storage)
NUXT_S3_ENDPOINT=https://s3.pub2.infomaniak.cloud
NUXT_S3_PUBLIC_BUCKET=public
NUXT_S3_PRIVATE_BUCKET=private
NUXT_S3_ACCESS_KEY_ID={accessKey}
NUXT_S3_SECRET_ACCESS_KEY={secretAccessKey}

# SMTP
NUXT_SMTP_HOST=mail.infomaniak.com
NUXT_SMTP_PORT=465
NUXT_SMTP_USER=noreply@web.site
NUXT_SMTP_FROM=noreply@web.site
NUXT_SMTP_PASS={smtpPassword}

# deployment
SERVER_URL={user}@{host}
SERVER_PORT=3000
PROJECT_NAME={name}
REMOTE_PATH="~/{path}"
SSH_KEY_NAME={sshKeyName}

# prod db
POSTGRES_USER={dbUser}
POSTGRES_PASSWORD={dbPassword}
POSTGRES_DB={dbName}
